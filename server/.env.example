NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autoflow_db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Alternative Redis configurations:
# For Redis with password:
# REDIS_URL=redis://:password@host:6379

# For Redis with TLS (Redis Cloud etc.):
# REDIS_URL=rediss://user:password@host:6380

JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

ANTHROPIC_API_KEY=sk-ant-your-key-here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM="AutoFlow AI <noreply@autoflow.ai>"

AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=autoflow-files

ENCRYPTION_KEY=your-32-char-encryption-key-here
WEBHOOK_TIMEOUT=30000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Step 5: Multi-Tenancy & Billing
ADMIN_SECRET=your-admin-panel-secret-here
TRIAL_DAYS=14
EXECUTION_RETENTION_DAYS=60
NOTIFICATION_RETENTION_DAYS=90
MAX_TEAM_MEMBERS_FREE=1

