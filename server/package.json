{
  "name": "autoflow-ai",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node src/app.js",
    "start": "node src/app.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset",
    "test": "dotenv -e .env.test -- vitest run",
    "test:watch": "dotenv -e .env.test -- vitest",
    "test:coverage": "dotenv -e .env.test -- vitest run --coverage",
    "test:unit": "dotenv -e .env.test -- vitest run tests/unit",
    "test:integration": "dotenv -e .env.test -- vitest run tests/integration",
    "test:e2e": "dotenv -e .env.test -- vitest run tests/e2e",
    "test:ci": "dotenv -e .env.test -- vitest run --coverage --reporter=junit",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.20.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.74.1",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "file-type": "^22.0.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jose": "^5.9.3",
    "js-yaml": "^4.1.1",
    "lru-cache": "^11.3.5",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.15",
    "openai": "^6.34.0",
    "puppeteer-core": "^24.41.0",
    "rate-limit-redis": "^4.3.1",
    "sanitize-html": "^2.13.0",
    "socket.io": "^4.8.3",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.3",
    "@vitest/coverage-v8": "^2.1.1",
    "autocannon": "^8.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.11.1",
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.1"
  }
}
